# Copy to .env.local and adjust for your machine.

# Release / notarization
# Used by scripts/release and scripts/release-direct-distribution.sh
APPLE_NOTARY_PROFILE=cloudspark-notary
GITHUB_REPOSITORY=zats/cloudspark

# Optional local project values
CLOUDFLARE2_BUNDLE_ID=com.zats.cloudspark2
CLOUDFLARE2_CODESIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)
CLOUDFLARE2_TEAM_ID=TEAMID
