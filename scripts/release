#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_SPEC_PATH="$ROOT_DIR/app/project.yml"
PROJECT_DIR="$ROOT_DIR/app"
RELEASE_HELPER_PATH="$ROOT_DIR/scripts/release-direct-distribution.sh"
APPCAST_HELPER_PATH="$ROOT_DIR/scripts/make-appcast.sh"
ASSET_NAME="Cloudspark-macos.zip"

NOTARY_PROFILE="${APPLE_NOTARY_PROFILE:-}"
REPO="${GITHUB_REPOSITORY:-}"
REMOTE="origin"
OUTPUT_DIR=""
DRAFT_RELEASE=0
ALLOW_PROVISIONING_UPDATES=0
DRY_RUN=0
IGNORED_STATUS_PATHS=(
  "app/Cloudspark.xcodeproj/project.xcworkspace/xcuserdata/zats.xcuserdatad/UserInterfaceState.xcuserstate"
  "app/Cloudspark.xcodeproj/xcuserdata/zats.xcuserdatad/xcschemes/xcschememanagement.plist"
)

usage() {
  cat <<'EOF'
Usage:
  scripts/release [options]

This script may be used for no-op release pipeline validation.

Options:
  --notary-profile NAME         Keychain profile for xcrun notarytool.
  --output-dir PATH             Where to write final artifacts. Default: temp dir.
  --repo OWNER/NAME             GitHub repo. Default: GITHUB_REPOSITORY or gh repo.
  --remote NAME                 Git remote to push. Default: origin.
  --draft                       Create the GitHub release as a draft.
  --dry-run                     Build/notarize locally but skip git/release/appcast changes.
  --allow-provisioning-updates  Pass through to xcodebuild archive.
  -h, --help                    Show help.

This script:
  1. Collects commit titles since the latest GitHub release tag.
  2. Bumps MARKETING_VERSION minor and CURRENT_PROJECT_VERSION.
  3. Regenerates the Xcode project, commits, and pushes the branch.
  4. Builds and notarizes the direct-distribution zip.
  5. Tags the release and creates the GitHub release.

With --dry-run:
  - Uses the same computed next version for the build.
  - Skips project file edits, commits, pushes, tags, GitHub release, and appcast.
EOF
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1" >&2
    exit 1
  fi
}

load_env_file() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    return
  fi
  set -a
  # shellcheck disable=SC1090
  source "$file"
  set +a
}

cleanup() {
  if [[ -n "${WORK_DIR:-}" && -d "${WORK_DIR:-}" ]]; then
    trash "$WORK_DIR" >/dev/null 2>&1 || true
  fi
}

project_setting() {
  local key="$1"
  ruby -e '
    path = ARGV[0]
    key = ARGV[1]
    line = File.readlines(path).find { |entry| entry =~ /^\s*#{Regexp.escape(key)}:\s*/ }
    abort("Missing #{key} in #{path}") unless line
    puts line.sub(/^\s*#{Regexp.escape(key)}:\s*/, "").strip
  ' "$PROJECT_SPEC_PATH" "$key"
}

bump_minor_version() {
  ruby -e '
    version = ARGV[0]
    parts = version.split(".")
    abort("Expected MARKETING_VERSION like X.Y, got #{version}") unless parts.length == 2 && parts.all? { |part| part.match?(/\A\d+\z/) }
    puts "#{parts[0]}.#{parts[1].to_i + 1}"
  ' "$1"
}

update_project_spec_versions() {
  local marketing_version="$1"
  local build_number="$2"
  ruby -e '
    path, marketing_version, build_number = ARGV
    content = File.read(path)
    original = content.dup
    content.sub!(/^(\s*MARKETING_VERSION:\s*).*$/, "\\1#{marketing_version}") || abort("Failed to update MARKETING_VERSION")
    content.sub!(/^(\s*CURRENT_PROJECT_VERSION:\s*).*$/, "\\1#{build_number}") || abort("Failed to update CURRENT_PROJECT_VERSION")
    abort("No changes written to #{path}") if content == original
    File.write(path, content)
  ' "$PROJECT_SPEC_PATH" "$marketing_version" "$build_number"
}

ensure_clean_worktree() {
  local status
  status="$(git status --short)"
  if [[ -n "$status" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local path="${line:3}"
      local ignored=0
      local ignored_path
      for ignored_path in "${IGNORED_STATUS_PATHS[@]}"; do
        if [[ "$path" == "$ignored_path" ]]; then
          ignored=1
          break
        fi
      done
      if [[ "$ignored" -eq 0 ]]; then
        echo "Worktree must be clean before release." >&2
        echo "$status" >&2
        exit 1
      fi
    done <<< "$status"
  fi
}

load_env_file "$ROOT_DIR/.env.local"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --notary-profile)
      NOTARY_PROFILE="${2:-}"
      shift 2
      ;;
    --output-dir)
      OUTPUT_DIR="${2:-}"
      shift 2
      ;;
    --repo)
      REPO="${2:-}"
      shift 2
      ;;
    --remote)
      REMOTE="${2:-}"
      shift 2
      ;;
    --draft)
      DRAFT_RELEASE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --allow-provisioning-updates)
      ALLOW_PROVISIONING_UPDATES=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

NOTARY_PROFILE="${NOTARY_PROFILE:-${APPLE_NOTARY_PROFILE:-}}"
REPO="${REPO:-${GITHUB_REPOSITORY:-}}"

require_command git
require_command ruby
require_command trash
require_command xcodegen
require_command python3
if [[ "$DRY_RUN" -eq 0 ]]; then
  require_command gh
fi

if [[ -z "$NOTARY_PROFILE" ]]; then
  echo "--notary-profile is required. Set it or export APPLE_NOTARY_PROFILE." >&2
  exit 1
fi

if [[ ! -f "$PROJECT_SPEC_PATH" ]]; then
  echo "Missing project spec: $PROJECT_SPEC_PATH" >&2
  exit 1
fi

if [[ ! -x "$RELEASE_HELPER_PATH" ]]; then
  echo "Missing release helper: $RELEASE_HELPER_PATH" >&2
  exit 1
fi

if [[ "$DRY_RUN" -eq 0 && ! -x "$APPCAST_HELPER_PATH" ]]; then
  echo "Missing appcast helper: $APPCAST_HELPER_PATH" >&2
  exit 1
fi

BRANCH="$(git symbolic-ref --quiet --short HEAD || true)"
if [[ -z "$BRANCH" ]]; then
  echo "Releases require a checked-out branch." >&2
  exit 1
fi

ensure_clean_worktree

if [[ "$DRY_RUN" -eq 0 && -z "$REPO" ]]; then
  REPO="$(gh repo view --json nameWithOwner -q .nameWithOwner)"
fi

git fetch "$REMOTE" --tags
BASE_COMMIT="$(git rev-parse HEAD)"
LAST_TAG="$(git describe --tags --abbrev=0 2>/dev/null || true)"
if [[ "$DRY_RUN" -eq 0 ]]; then
  LAST_TAG="$(gh release list --repo "$REPO" --exclude-drafts --exclude-pre-releases --limit 1 --json tagName --jq '.[0].tagName')"
  if [[ "$LAST_TAG" == "null" ]]; then
    LAST_TAG=""
  fi
fi

WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/cloudspark-release.XXXXXX")"
trap cleanup EXIT
if [[ -n "$OUTPUT_DIR" ]]; then
  RELEASE_OUTPUT_DIR="$OUTPUT_DIR"
  mkdir -p "$RELEASE_OUTPUT_DIR"
else
  RELEASE_OUTPUT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/cloudspark-release-output.XXXXXX")"
fi
NOTES_FILE="$RELEASE_OUTPUT_DIR/release-notes.md"

if [[ -n "$LAST_TAG" ]]; then
  git rev-parse "$LAST_TAG^{commit}" >/dev/null 2>&1 || git fetch "$REMOTE" "refs/tags/$LAST_TAG:refs/tags/$LAST_TAG"
  git log --format='- %s' --reverse --no-merges "$LAST_TAG..$BASE_COMMIT" > "$NOTES_FILE"
else
  git log --format='- %s' --reverse --no-merges "$BASE_COMMIT" > "$NOTES_FILE"
fi

if [[ ! -s "$NOTES_FILE" ]]; then
  echo "No commit titles found since ${LAST_TAG:-the beginning}." >&2
  exit 1
fi

CURRENT_MARKETING_VERSION="$(project_setting MARKETING_VERSION)"
CURRENT_BUILD_NUMBER="$(project_setting CURRENT_PROJECT_VERSION)"
if [[ ! "$CURRENT_BUILD_NUMBER" =~ ^[0-9]+$ ]]; then
  echo "CURRENT_PROJECT_VERSION must be numeric." >&2
  exit 1
fi

NEXT_MARKETING_VERSION="$(bump_minor_version "$CURRENT_MARKETING_VERSION")"
NEXT_BUILD_NUMBER="$((CURRENT_BUILD_NUMBER + 1))"
VERSION="${NEXT_MARKETING_VERSION}.${NEXT_BUILD_NUMBER}"
TAG="v$VERSION"
TITLE="Cloudspark $VERSION"

if git rev-parse "$TAG^{tag}" >/dev/null 2>&1 || git ls-remote --exit-code --tags "$REMOTE" "refs/tags/$TAG" >/dev/null 2>&1; then
  echo "Tag already exists: $TAG" >&2
  exit 1
fi

if [[ "$DRY_RUN" -eq 0 ]] && gh release view "$TAG" --repo "$REPO" >/dev/null 2>&1; then
  echo "GitHub release already exists: $TAG" >&2
  exit 1
fi

echo "Bumping version to $VERSION"
echo "Building and notarizing $TITLE"
HELPER_ARGS=(
  --notary-profile "$NOTARY_PROFILE"
  --output-dir "$RELEASE_OUTPUT_DIR"
  --marketing-version "$NEXT_MARKETING_VERSION"
  --build-number "$NEXT_BUILD_NUMBER"
  --tag "$TAG"
  --title "$TITLE"
)
if [[ "$ALLOW_PROVISIONING_UPDATES" -eq 1 ]]; then
  HELPER_ARGS+=( --allow-provisioning-updates )
fi
"$RELEASE_HELPER_PATH" "${HELPER_ARGS[@]}"

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo
  echo "Dry run complete"
  echo "Version: $VERSION"
  echo "Tag: $TAG"
  echo "Artifact: $RELEASE_OUTPUT_DIR/$ASSET_NAME"
  echo "Notes: $NOTES_FILE"
  exit 0
fi

echo "Writing release version to project files"
update_project_spec_versions "$NEXT_MARKETING_VERSION" "$NEXT_BUILD_NUMBER"
xcodegen generate --spec "$PROJECT_SPEC_PATH" --project "$PROJECT_DIR" --quiet

git add "$PROJECT_SPEC_PATH" "$ROOT_DIR/app/Cloudspark.xcodeproj/project.pbxproj"
git commit -m "Release $VERSION"

echo "Pushing branch $BRANCH"
git push "$REMOTE" "HEAD:refs/heads/$BRANCH"

echo "Tagging $TAG"
git tag -a "$TAG" -m "$TITLE"
git push "$REMOTE" "refs/tags/$TAG"

RELEASE_ARGS=(
  "$TAG"
  "$RELEASE_OUTPUT_DIR/$ASSET_NAME#$ASSET_NAME"
  --repo "$REPO"
  --title "$TITLE"
  --notes-file "$NOTES_FILE"
  --verify-tag
)
if [[ "$DRAFT_RELEASE" -eq 1 ]]; then
  RELEASE_ARGS+=( --draft )
fi

echo "Creating GitHub release $TAG"
gh release create "${RELEASE_ARGS[@]}"

echo "Generating appcast for $TAG"
"$APPCAST_HELPER_PATH" "$RELEASE_OUTPUT_DIR/$ASSET_NAME" "$VERSION" "$TAG" "$NOTES_FILE"

git add "$ROOT_DIR/appcast.xml"
git commit -m "Update appcast for $VERSION"
git push "$REMOTE" "HEAD:refs/heads/$BRANCH"

echo
echo "Version: $VERSION"
echo "Branch: $BRANCH"
echo "Tag: $TAG"
echo "Artifact: $RELEASE_OUTPUT_DIR/$ASSET_NAME"
echo "Notes: $NOTES_FILE"
echo "Appcast: $ROOT_DIR/appcast.xml"
